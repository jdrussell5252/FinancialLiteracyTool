<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinancialLiteracyTool</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FinancialLiteracyTool.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <!-- Top Header -->
    <header class="bg-dark py-2 d-flex justify-content-between align-items-center px-3">
        <button class="btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebar" aria-controls="sidebar">
            <i class="bi bi-list"></i> <!-- Hamburger icon -->
        </button>

        <div class="logo text-center">
            <img src="https://lirp.cdn-website.com/30ef7c41/dms3rep/multi/opt/Logo+-+Plaid-1920w.png" alt="Logo" style="max-height:60px;">
        </div>

        <div style="width: 40px;"><!-- Placeholder for alignment --></div>
    </header>

    <!-- Sidebar (Offcanvas) -->
    <div class="offcanvas offcanvas-start bg-dark text-white" tabindex="-1" id="sidebar" aria-labelledby="sidebarLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="sidebarLabel">Menu</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">

            <a class="d-block py-2 text-white" asp-area="" asp-page="/Index">Home</a>

            @if (!User.Identity.IsAuthenticated)
            {
                <a class="d-block py-2 text-white" asp-area="" asp-page="/Account/Login">Login</a>
                <a class="d-block py-2 text-white" asp-area="" asp-page="/Account/Register">Register</a>
            }

            @if (User.Identity.IsAuthenticated)
            {

                <a class="d-block py-2 text-white" asp-area="" asp-page="/Assessment/UserConfirmAssessment">Take Assessment</a>

                var isAdmin = ViewData["IsAdmin"] != null && (bool)ViewData["IsAdmin"];
                @if (isAdmin)
                {

                    <a class="d-block py-2 text-white" asp-area="" asp-page="/AdminPages/Users/BrowseUsers">Browse Users</a>
                    <a class="d-block py-2 text-white" asp-area="" asp-page="/AdminPages/Questions/BrowseQuestions">Browse Questions</a>
                    <a class="d-block py-2 text-white" asp-area="" asp-page="/AdminPages/AdminAssessment/BrowseAssessments">Browse Assessments</a>
                }

                var isCoach = ViewData["IsCoach"] != null && (bool)ViewData["IsCoach"];
                @if (isCoach)
                {
                    <a class="d-block py-2 text-white" asp-area="" asp-page="/CoachPages/SuggestAssessment">Suggest Assessments</a>
                }
                <a class="d-block py-2 text-white" asp-area="" asp-page="/Account/Profile">Profile</a>
                <a class="d-block py-2 text-white" asp-area="" asp-page="/Account/SignOut">Sign Out</a>
            }
        </div>
    </div>
    <div class="container-fluid p-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class=footer>
        <div class="container">
            &copy; 2026 - FinancialLiteracyTool - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>