@page
@model FinancialLiteracyTool.Pages.UserPages.TakeAssessmentModel
@{
}

<style>
    .question {
        display: none;
    }

        .question.active {
            display: block;
        }
</style>

<div class="exam-container">
    <div id="questionContainer">
        @for (int i = 0; i < Model.Questions.Count; i++)
        {
            var q = Model.Questions[i];

            <div class="question">
                <div class="fw-bold mb-2">
                    Question @(i + 1) of @Model.Questions.Count
                </div>

                <div class="mb-3">@q.QuestionText</div>

                @foreach (var c in Model.Choices.Where(x => x.QuestionID == q.QuestionID))
                {
                    <label class="choice-option">
                        <input type="radio"
                               name="q_@q.QuestionID"
                               value="@c.QuestionChoiceID" />
                        @c.QuestionChoiceText
                    </label>
                }
            </div>
        }
    </div>
</div>

<div class="text-center mt-3">
    <button id="prevBtn" class="btn btn-secondary">Previous</button>
    <button id="nextBtn" class="btn btn-primary">Next</button>
    <button id="finishBtn" class="btn btn-success" style="display:none;">Finish</button>
</div>

<script>
    let currentQuestion = 0;

    var lastIndex = localStorage.getItem("index");
    if (lastIndex != null && JSON.parse(localStorage.getItem("index"))[@Model.CurrAssessmentID] != undefined) {
        currentQuestion = JSON.parse(localStorage.getItem("index"))[@Model.CurrAssessmentID];
    }

    const questions = document.querySelectorAll(".question");
    const total = questions.length;

    // =============================
    // SHOW QUESTION
    // =============================
    function showQuestion(index) {
        questions.forEach((q, i) => {
            q.classList.remove("active");
            if (i === index) q.classList.add("active");
        });

        document.getElementById("prevBtn").style.display = index === 0 ? "none" : "inline-block";
        document.getElementById("nextBtn").style.display = index === total - 1 ? "none" : "inline-block";
        document.getElementById("finishBtn").style.display = index === total - 1 ? "inline-block" : "none";
    }

    // =============================
    // SAVE ANSWERS
    // =============================
    document.querySelectorAll('input[type="radio"]').forEach(r => {
        r.addEventListener('change', async (e) => {

            const qId = r.name.replace("q_", "");
            const answers = JSON.parse(localStorage.getItem("answers") || "{}");
            const index = JSON.parse(localStorage.getItem("index") || "{}");

            answers[qId] = r.value;
            index[@Model.CurrAssessmentID] = currentQuestion;
            localStorage.setItem("answers", JSON.stringify(answers));
            localStorage.setItem("index", JSON.stringify(index));

            const indexJSON = localStorage.getItem("index") || "{}";

            // Save curr index
            await fetch("@Url.Page("/UserPages/TakeAssessment", "SaveIndex")", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: indexJSON
            });

            // Highlight selected
            const parent = r.closest(".question");
            parent.querySelectorAll(".choice-option").forEach(opt => {
                opt.classList.remove("selected");
            });

            r.parentElement.classList.add("selected");
        });
    });

    // =============================
    // RESTORE ANSWERS
    // =============================
    function restoreAnswers() {
        const answers = JSON.parse(localStorage.getItem("answers") || "{}");

        Object.keys(answers).forEach(qId => {
            const value = answers[qId];

            const radios = document.querySelectorAll(`input[name="q_${qId}"]`);
            radios.forEach(r => {
                if (r.value === value) {
                    r.checked = true;
                    r.parentElement.classList.add("selected");
                }
            });
        });
    }

    // =============================
    // NEXT BUTTON (validation added)
    // =============================
    document.getElementById("nextBtn").addEventListener("click", () => {
        const radios = questions[currentQuestion].querySelectorAll('input[type="radio"]');
        const answered = Array.from(radios).some(r => r.checked);

        if (!answered) {
            alert("Please select an answer before continuing.");
            return;
        }

        currentQuestion++;
        showQuestion(currentQuestion);
    });

    // =============================
    // PREVIOUS BUTTON
    // =============================
    document.getElementById("prevBtn").addEventListener("click", () => {
        currentQuestion--;
        showQuestion(currentQuestion);
    });

    // =============================
    // SUBMIT TO BACKEND
    // =============================
    document.getElementById("finishBtn").addEventListener("click", async (e) => {
        e.preventDefault();

        const answers = localStorage.getItem("answers") || "{}";
        const index = localStorage.getItem("index") || "{}";

        const res = await fetch("@Url.Page("/UserPages/TakeAssessment", "SaveAnswers")", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]')?.value
            },
            body: answers
        });

        if (res.ok) {
            window.location.href = "@Url.Page("/UserPages/ConfirmSubmission")?id=@Model.CurrAssessmentID&NumQuestions=@Model.NumQuestions";
        } else {
            alert("Could not save answers. Please try again.");
        }


    });

    // =============================
    // INIT
    // =============================
    restoreAnswers();
    showQuestion(currentQuestion);
</script>
<form method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>