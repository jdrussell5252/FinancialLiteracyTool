@page
@model FinancialLiteracyTool.Pages.Account.EditPasswordModel
@{
}

<div class="row text-center">
    <div class="col-12">
        <label class="form-label fs-1" id="LabelText">Edit Password</label>
    </div>
</div>

<form method="post">

    <div class="row">
        <div class="col-4">
            <label asp-for="Profile.MyPassword" class="form-label" id="LabelText">New Password:</label>
        </div>
        <div class="col-12">
            <input asp-for="Profile.MyPassword" type="password" class="form-control" />
            <span asp-validation-for="Profile.MyPassword" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <label asp-for="Profile.ConfirmPassword" class="form-label" id="LabelText">Confirm Password:</label>
        </div>
        <div class="col-12">
            <input asp-for="Profile.ConfirmPassword" type="password" class="form-control" />
            <span asp-validation-for="Profile.ConfirmPassword" class="text-danger"></span>
        </div>
    </div>

    <div class="row my-2">
        <div class="col-12">
            <button type="submit" class="form-control btn btn-primary">Confirm Edit</button>
        </div>
    </div>
</form>