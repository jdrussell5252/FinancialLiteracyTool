@page
@model FinancialLiteracyTool.Pages.AdminPages.Users.BrowseUsersModel
@{
}

<div class="areas-container">
    <div class="row text-center">
        <div class="col-12">
            <label class="form-label fs-1">Browse Users</label>
        </div>
    </div>

    <!--=================== Add Button ==================-->
    <div class="row mb-3">
        <div class="col-12">
            <a asp-page="AddUser" class="btn btn-primary">
                <i class="bi bi-plus-square"></i> Add User
            </a>
        </div>
    </div>
    <!--=================== End Add Button ==================-->


    <div class="areas-card">

        <h1 class="areas-title">Users</h1>

        <table class="areas-table">

            <thead>
                <tr>
                    <th>Name</th>
                    <th>Username</th>
                    <th>Role</th>
                    <th>Coach</th>
                    <th class="text-end">Manage</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.Users != null && Model.Users.Count > 0)
                {
                    @foreach (var u in Model.Users)
                    {
                        <tr>

                            <!-- Name -->
                            <td>
                                <div class="area-name">
                                    @u.UserFName @u.UserLName
                                </div>
                            </td>

                            <!-- Username -->
                            <td>@u.SystemUsername</td>

                            <!-- Role -->
                            <td>
                                @(u.SystemUserRole == 3 ? "Admin" :
                                  u.SystemUserRole == 2 ? "Coach" :
                                                          "User")
                            </td>

                            <!-- Coach's Name -->
                            <td>
                                @(string.IsNullOrEmpty(u.CoachFirstName)
                                    ? "N/A"
                                    : @u.CoachFirstName + " " + u.CoachLastName)
                            </td>
                            <!-- Actions -->
                            <td class="text-end">

                                <a asp-page="/AdminPages/Users/EditUsers"
                                   asp-route-id="@u.UserID"
                                   class="action-btn">
                                    Edit
                                </a>

                                <form method="post"
                                      asp-page-handler="Delete"
                                      style="display:inline;">

                                    <input type="hidden"
                                           name="id"
                                           value="@u.UserID" />

                                    <button onclick="return confirm('Are you sure?')"
                                            class="delete-btn ms-2">
                                        <i class="bi bi-trash3"></i>
                                    </button>

                                </form>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="empty-message text-center">
                            No users found.
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

    <!-- Pagination -->
    @if (Model.TotalCount > 0)
    {
        <div class="text-center my-4">

            <div class="pagination justify-content-center">

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.PageNumber)
                    {
                        <span class="page-number active">@i</span>
                    }
                    else
                    {
                        <a class="page-number"
                           asp-page="./BrowseUsers"
                           asp-route-pageNumber="@i"
                           asp-route-pageSize="@Model.PageSize">
                            @i
                        </a>
                    }
                }

            </div>

        </div>
    }

</div>