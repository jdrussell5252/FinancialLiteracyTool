@page
@model FinancialLiteracyTool.Pages.AdminPages.Users.BrowseUsersModel
@{
}

<div class="row text-center mb-4">
    <div class="col-12">
        <h1>Browse Users</h1>
    </div>
</div>

<div class="container mt-4">

    <!-- Add Button -->
    <div class="row mb-3">
        <div class="col-12">
            <a asp-page="AddUser" class="btn btn-primary">
                <i class="bi bi-plus-square"></i> Add User
            </a>
        </div>
    </div>

    <!-- Error Message -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (Model.Users.Count != 0)
    {

        <div class="card shadow-sm p-4">
            <h3 class="mb-4">User</h3>

            <table class="table align-middle">

                <thead class="text-muted">
                    <tr>
                        <th>Name</th>
                        <th>Username</th>
                        <th>Role</th>
                        <th class="text-end">Manage</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var u in Model.Users)
                    {
                        <tr>
                            <td>
                                <strong>@u.UserFName @u.UserLName</strong>
                            </td>

                            <td>
                                @u.SystemUsername
                            </td>
                            
                            <td>
                                @(u.IsAdmin ? "Admin" : "User")
                            </td>

                            <td class="text-end">
                                <a asp-page="/AdminPages/Users/EditUsers"
                                   asp-route-id="@u.UserID"
                                   class="btn btn-primary btn-sm rounded-pill px-3">
                                    Edit
                                </a>

                                <form method="post"
                                      asp-page-handler="Delete"
                                      style="display:inline;">

                                    <input type="hidden"
                                           name="id"
                                           value="@u.UserID" />

                                    <button onclick="return confirm('Are you sure?')"
                                            class="btn btn-danger btn-sm rounded-pill px-3 ms-2">
                                        <i class="bi bi-trash3"></i>
                                    </button>

                                </form>

                            </td>

                        </tr>
                    }
                </tbody>

            </table>

        </div>
    }
    else
    {
        <div class="text-center mt-4">
            <h4>No users yet.</h4>
        </div>
    }

</div>