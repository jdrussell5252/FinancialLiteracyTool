@page
@model FinancialLiteracyTool.Pages.UserPages.TakeAssessmentModel
@{
}

<style>
    .question {
        display: none;
    }

        .question.active {
            display: block;
        }
</style>

<div class="container mt-4">

    @for (int i = 0; i < Model.Questions.Count; i++)
    {
        var q = Model.Questions[i];

        <div class="question">
            <div class="fw-bold mb-2">
                Question @(i + 1) of @Model.Questions.Count
            </div>

            <div class="mb-3">@q.QuestionText</div>

            @foreach (var c in Model.Choices.Where(x => x.QuestionID == q.QuestionID))
            {
                <div>
                    <input type="radio"
                           name="q_@q.QuestionID"
                           value="@c.QuestionChoiceID" />
                    @c.QuestionChoiceText
                </div>
            }
        </div>
    }

</div>

<div class="text-center mt-3">
    <button id="prevBtn" class="btn btn-secondary">Previous</button>
    <button id="nextBtn" class="btn btn-primary">Next</button>
    <button id="finishBtn" class="btn btn-success" style="display:none;">Finish</button>
</div>

<script>
    let currentQuestion = 0;
    const questions = document.querySelectorAll(".question");

    function showQuestion(index) {
        questions.forEach((q, i) => {
            q.classList.remove("active");
            if (i === index) q.classList.add("active");
        });

        document.getElementById("prevBtn").style.display = index === 0 ? "none" : "inline-block";
        document.getElementById("nextBtn").style.display = index === questions.length - 1 ? "none" : "inline-block";
        document.getElementById("finishBtn").style.display = index === questions.length - 1 ? "inline-block" : "none";
    }

    // SAVE (SESSION ONLY)
    document.querySelectorAll('input[type="radio"]').forEach(r => {
        r.addEventListener('change', () => {
            const answers = JSON.parse(sessionStorage.getItem("answers") || "{}");
            answers[r.name] = r.value;
            sessionStorage.setItem("answers", JSON.stringify(answers));
        });
    });

    // RESTORE
    function restore() {
        const answers = JSON.parse(sessionStorage.getItem("answers") || "{}");

        Object.keys(answers).forEach(key => {
            const input = document.querySelector(`input[name="${key}"][value="${answers[key]}"]`);
            if (input) input.checked = true;
        });
    }

    document.getElementById("nextBtn").onclick = () => {
        currentQuestion++;
        showQuestion(currentQuestion);
    };

    document.getElementById("prevBtn").onclick = () => {
        currentQuestion--;
        showQuestion(currentQuestion);
    };

    document.getElementById("finishBtn").onclick = async () => {
        const answers = sessionStorage.getItem("answers") || "{}";
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        const res = await fetch("?handler=SaveAnswers", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "RequestVerificationToken": token
            },
            body: answers
        });

        if (res.ok) {
           window.location.href = `/UserPages/ConfirmSubmission?id=@(Request.Query["id"])&userAssessmentID=@Model.CurrAssessmentID&NumQuestions=@Model.NumQuestions`;
        }
    };

    restore();
    showQuestion(0);
</script>
<form method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>