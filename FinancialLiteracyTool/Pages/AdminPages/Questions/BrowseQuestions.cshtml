@page
@model FinancialLiteracyTool.Pages.AdminPages.Questions.BrowseQuestionsModel
@{
}

<div class="row text-center mb-4">
    <div class="col-12">
        <h1>Browse Questions</h1>
    </div>
</div>

<div class=" container mt-4">
    <!--===================Add Button==================-->
    <div class="row mb-3">
        <div class="col-12">
            <a asp-page="AddQuestion" class="btn btn-primary">
                <i class="bi bi-plus-square"></i> Add Question
            </a>
        </div>
    </div>
    <!--===================End Add Button==================-->
    <!-- Error Message -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (Model.Questions.Count != 0)
    {

        <div class="row">

            @foreach (var LocalQuestion in Model.Questions)
            {
                <div class="col-md-6 col-lg-4 mb-4">

                    <div class="card shadow-sm h-100">

                        <div class="card-body">

                            <!-- Question Text -->
                            <h5 class="card-title mb-3">
                                @LocalQuestion.QuestionText
                            </h5>

                            <!-- Question Area -->
                            <p class="mb-1">
                                <strong>Area:</strong> @LocalQuestion.QuestionArea
                            </p>

                            <!-- Question Type -->
                            <p class="mb-3">
                                <strong>Type:</strong> @LocalQuestion.QuestionType
                            </p>

                            <!-- Choices -->
                            <p class="fw-bold">Choices:</p>

                            <ul class="mb-3">
                                @foreach (var c in LocalQuestion.Choices)
                                {
                                    <li>@c.QuestionChoiceText</li>
                                }
                            </ul>

                        </div>

                        <div class="card-footer d-flex justify-content-between">

                            <!-- Edit Question -->
                            <a asp-page="EditQuestion"
                               asp-route-id="@LocalQuestion.QuestionID"
                               class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil-square"></i> Edit
                            </a>

                            <!-- Delete -->
                            <form method="post" asp-page-handler="Delete">
                                <input type="hidden" name="id" value="@LocalQuestion.QuestionID" />

                                <button onclick="return confirm('Are you sure?')"
                                        class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </form>

                        </div>

                    </div>

                </div>
            }

        </div>

        @if (Model.TotalCount > 0)
        {
            <div class="text-center my-4">

                <div class="pagination justify-content-center">

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.PageNumber)
                        {
                            <span class="page-number active">@i</span>
                        }
                        else
                        {
                            <a class="page-number"
                               asp-page="./BrowseQuestions"
                               asp-route-pageNumber="@i"
                               asp-route-pageSize="@Model.PageSize">
                                @i
                            </a>
                        }
                    }

                </div>

            </div>
        }

    }
    else
    {
        <div class="row my-4 text-center">
            <div class="col-12">
                <h4>No questions yet.</h4>
            </div>
        </div>
    }
</div>