@page
@model BrowseUserAssessmentsModel
@{
}

<div class="row text-center mb-4">
    <div class="col-12">
        <h1>Browse Assessments</h1>
    </div>
</div>

<div class="container mt-4">

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (Model.Assessments.Count != 0)
    {

        <div class="row">

            @foreach (var LocalAssessment in Model.Assessments)
            {
                <div class="col-md-6 col-lg-4 col-xl-3 mb-4">

                    <div class="card shadow-sm h-100">

                        <div class="card-body text-center">

                            <h5 class="card-title">
                                @LocalAssessment.AssessmentName
                            </h5>

                            @if (!string.IsNullOrWhiteSpace(LocalAssessment.AssessmentDescription))
                            {
                                <p class="card-text text-muted small">
                                    @LocalAssessment.AssessmentDescription
                                </p>
                            }

                        </div>

                    </div>

                </div>
            }

        </div>

        @if (Model.TotalCount > 0)
        {
            <div class="text-center my-4">

                <div class="pagination justify-content-center">

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.PageNumber)
                        {
                            <span class="page-number active">@i</span>
                        }
                        else
                        {
                            <a class="page-number"
                               asp-page="./BrowseUserAssessments"
                               asp-route-pageNumber="@i"
                               asp-route-pageSize="@Model.PageSize">
                                @i
                            </a>
                        }
                    }

                </div>

            </div>
        }

    }
    else
    {
        <div class="text-center my-4">
            <h4>No Assessments yet.</h4>
        </div>
    }

</div>