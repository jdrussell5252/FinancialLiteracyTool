@page
@model FinancialLiteracyTool.Pages.Account.ProfileModel
@{
}

<div class="areas-container">
    <div class="row text-center">
        <div class="col-12">
            <label class="form-label fs-1" id="LabelText">Profile</label>
        </div>
    </div>

    <div class="row mt-4">

        <!-- LEFT SIDE : PROFILE -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">

                    <img src="@Model.CurrentProfile.SystemUserProfileImagePath"
                         alt="User Picture"
                         class="profile-pic mb-3" />

                    <h2 class="text-dark">
                        @Model.CurrentProfile.SystemUserName
                    </h2>

                    <a asp-page="/Account/EditProfile"
                       asp-route-id="@Model.CurrentProfile.SystemUserID"
                       class="btn btn-primary mt-2">
                        Edit Profile
                    </a>

                    <hr />

                    <h5>Account Settings</h5>

                    <a asp-page="/Account/EditPassword"
                       asp-route-id="@Model.CurrentProfile.SystemUserID"
                       class="btn btn-primary">
                        Change Password
                    </a>

                </div>
            </div>
        </div>

        <!-- RIGHT SIDE : PROGRESS -->
        <div class="col-md-8">

            <div class="card shadow-sm">
                <div class="card-body">

                    <h4 class="mb-4">My Progress</h4>

                    <div class="row text-center">

                        <!-- Assessments Taken -->
                        <div class="col-md-6">
                            <h5>Assessments Taken</h5>
                            <h2 class="fw-bold display-5">
                                @Model.AssessmentsTaken
                            </h2>
                        </div>

                        <!-- Highest Score -->
                        <div class="col-md-6">
                            <h5>Highest Score</h5>
                            <h2 class="fw-bold display-5">
                                0%
                            </h2>
                        </div>

                    </div>

                </div>
            </div>

        </div>

    </div>

</div>
