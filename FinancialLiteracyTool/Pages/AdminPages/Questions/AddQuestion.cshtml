@page
@model FinancialLiteracyTool.Pages.AdminPages.Questions.AddQuestionModel
@{
}

<div class="row text-center">
    <div class="col-12">
        <label class="form-label fs-1" id="LabelText">Add Question</label>
    </div>
</div>

<form method="post">

    <div class="row">

        <!--===================Question Text Textbox==================-->
        <div class="row">
            <div class="col-4">
                <label asp-for="NewQuestion.QuestionText" class="form-label" id="LabelText">Question Text:</label>
            </div>
            <div class="col-12">
                <input asp-for="NewQuestion.QuestionText" type="text" class="form-control" />
                <span asp-validation-for="NewQuestion.QuestionText" class="text-danger"></span>
            </div>
        </div>
        <!--===================End of Question Text Textbox==================-->

        <!--===================Question Area Textbox==================-->

        <div class="col-6 mt-2">
            <label asp-for="SelectedQuestionAreaID" class="form-label" id="LabelText">Question Area:</label>
        </div>

        <div class="col-12">
            <select asp-for="SelectedQuestionAreaID" asp-items="Model.QuestionArea" class="form-control">
            </select>
            <span asp-validation-for="SelectedQuestionAreaID" class="text-danger"></span>
        </div>
        <!--===================End of Question Area Textbox==================-->

        <!--===================Question Type Textbox==================-->

        <div class="col-6 mt-2">
            <label asp-for="SelectedQuestionTypeID" class="form-label" id="LabelText">Question Type:</label>
        </div>

        <div class="col-12">
            <select id="questionTypeSelect"
                    asp-for="SelectedQuestionTypeID"
                    asp-items="Model.QuestionType"
                    class="form-control">
            </select>
        </div>
        <!--===================End of Question Type Textbox==================-->

        <!--===================Question Choices Textbox==================-->

        <div id="mcChoices" style="display:none;">
            <div class="row mt-3">
                <div class="col-4">
                    <label class="form-label" id="LabelText">Choice 1:</label>
                </div>
                <div class="col-12">
                    <input name="Choices[0]" type="text" class="form-control" />
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-4">
                    <label class="form-label" id="LabelText">Choice 2:</label>
                </div>
                <div class="col-12">
                    <input name="Choices[1]" type="text" class="form-control" />
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-4">
                    <label class="form-label" id="LabelText">Choice 3:</label>
                </div>
                <div class="col-12">
                    <input name="Choices[2]" type="text" class="form-control" />
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-4">
                    <label class="form-label" id="LabelText">Choice 4:</label>
                </div>
                <div class="col-12">
                    <input name="Choices[3]" type="text" class="form-control" />
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-12">
                    <label class="form-label" id="LabelText">Correct Answer:</label>

                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="CorrectChoiceIndex" value="0">
                        <label class="form-check-label">Choice 1</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="CorrectChoiceIndex" value="1">
                        <label class="form-check-label">Choice 2</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="CorrectChoiceIndex" value="2">
                        <label class="form-check-label">Choice 3</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="CorrectChoiceIndex" value="3">
                        <label class="form-check-label">Choice 4</label>
                    </div>

                    <span asp-validation-for="CorrectChoiceIndex" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div id="tfChoices" style="display:none;">
            <div class="row mt-3">
                <div class="col-12">
                    <div class="form-text">True/False will be auto-created as choices.</div>
                </div>
            </div>
        </div>
        <!--===================End of Question Choices Textbox==================-->

        <!--===================Submit Button==================-->
        <div class="row my-2">
            <div class="col-12">
                <button type="submit" class="form-control btn btn-primary"> Confirm </button>
            </div>
        </div>
        <!--=================End of Submit Button==================-->
    </div>
</form>

<script>
    function toggleChoiceUI() {
        const select = document.getElementById('questionTypeSelect');
        if (!select) return;

        const selectedText = (select.options[select.selectedIndex]?.text || "").toLowerCase();

        const mc = document.getElementById('mcChoices');
        const tf = document.getElementById('tfChoices');

        const isMultiple = selectedText.includes("multiple");
        const isTrueFalse = selectedText.includes("truefalse");

        if (isMultiple) {
            mc.style.display = "block";
            tf.style.display = "none";
        } else if (isTrueFalse) {
            mc.style.display = "none";
            tf.style.display = "block";
        } else {
            mc.style.display = "none";
            tf.style.display = "none";
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        toggleChoiceUI();
        document.getElementById('questionTypeSelect').addEventListener('change', toggleChoiceUI);
    });
</script>