@page
@model BrowseUserAssessmentsModel
@{
}

<style>
    body {
        background-color: #f5f7fb;
    }

    .card {
        border: none;
        border-radius: 16px;
        transition: all 0.3s ease;
    }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

    .card-title {
        font-weight: 600;
        font-size: 1.2rem;
    }

    .btn-primary, .btn-success {
        border-radius: 10px;
        font-weight: 500;
    }

    .header-title {
        font-weight: 700;
        font-size: 2.2rem;
    }

    .subtitle {
        color: #6c757d;
    }
</style>

<div class="container py-4">

    <div class="text-center mb-5">
        <h1 class="header-title">Browse Assessments</h1>
        <p class="subtitle">Choose an assessment to get started</p>
    </div>

    @if (Model.Assessments.Count != 0)
    {
        <div class="row g-4">

            @foreach (var a in Model.Assessments)
            {
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <div class="card-body text-center d-flex flex-column">

                        <h5 class="card-title">@a.AssessmentName</h5>

                        @if (!string.IsNullOrWhiteSpace(a.AssessmentDescription))
                        {
                            <p class="text-muted small">@a.AssessmentDescription</p>
                        }

                        <div class="mb-3">
                            @if (a.Status == "Completed")
                            {
                                <span class="badge bg-success">Completed</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Not Started</span>
                            }
                        </div>

                        <div class="mt-auto">
                            @if (a.Status == "Completed")
                            {
                                <a class="btn btn-secondary w-100 disabled" aria-disabled="true">
                                    Already Completed
                                </a>
                            }
                            else
                            {
                                <a asp-page="/UserPages/TakeAssessment"
                                   asp-route-id="@a.AssessmentID"
                                   asp-route-userAssessmentID="@a.UserAssessmentID"
                                   class="btn btn-primary w-100">
                                    Start Assessment
                                </a>
                            }
                        </div>

                    </div>
                </div>
            }

        </div>
    }
    else
    {
        <div class="text-center mt-5">
            <h4>No Assessments Assigned</h4>
        </div>
    }

</div>