@page
@model FinancialLiteracyTool.Pages.Assessment.TakeAssessmentModel
@{
}

<style>
    body {
        background-color: #f8f9fa;
    }

    
</style>

<div class="exam-container">
    <div id="questionContainer">
        @foreach (var q in Model.Questions.Take(30))
        {
            <div class="question mb-4">
                <div class="fw-bold mb-2">
                    Question @(Model.Questions.Take(30).ToList().IndexOf(q) + 1)
                    of @Model.Questions.Take(30).Count()
                </div>

                <div class="mb-3">@q.QuestionText</div>

                @foreach (var c in Model.Choices.Where(x => x.QuestionID == q.QuestionID))
                {
                    var safeChoice = c.QuestionChoiceText.Replace(" ", "_").Replace("\"", "").Replace("'", "");
                    var inputId = $"q{q.QuestionID}_{safeChoice}";

                    <label class="choice-option">
                        <input type="radio"
                               id="@inputId"
                               name="q_@q.QuestionID"
                               value="@c.QuestionChoiceText" />
                        @c.QuestionChoiceText
                    </label>
                }
            </div>
        }
    </div>
</div>

<!-- Navigation -->
<div class="nav-buttons">
    <button class="btn btn-secondary" id="prevBtn">Previous</button>
    <button class="btn btn-primary" id="nextBtn">Next</button>

    <a asp-page="/Assessment/ConfirmSubmission"
           class="btn btn-success"
           id="finishBtn"
           style="display:none;">
        Finish Assessment
    </a>
</div>

<script>
    let currentQuestion = 0;
    const questions = document.querySelectorAll(".question");
    const total = questions.length;

    // =============================
    // SHOW QUESTION
    // =============================
    function showQuestion(index) {
        questions.forEach((q, i) => {
            q.classList.remove("active");
            if (i === index) q.classList.add("active");
        });

        document.getElementById("prevBtn").style.display = index === 0 ? "none" : "inline-block";
        document.getElementById("nextBtn").style.display = index === total - 1 ? "none" : "inline-block";
        document.getElementById("finishBtn").style.display = index === total - 1 ? "inline-block" : "none";
    }

    // =============================
    // SAVE ANSWERS
    // =============================
    document.querySelectorAll('input[type="radio"]').forEach(r => {
        r.addEventListener('change', () => {
            const qId = r.name.replace("q_", "");
            const answers = JSON.parse(sessionStorage.getItem("answers") || "{}");

            answers[qId] = r.value;
            sessionStorage.setItem("answers", JSON.stringify(answers));

            // Highlight selected
            const parent = r.closest(".question");
            parent.querySelectorAll(".choice-option").forEach(opt => {
                opt.classList.remove("selected");
            });

            r.parentElement.classList.add("selected");
        });
    });

    // =============================
    // RESTORE ANSWERS
    // =============================
    function restoreAnswers() {
        const answers = JSON.parse(sessionStorage.getItem("answers") || "{}");

        Object.keys(answers).forEach(qId => {
            const value = answers[qId];

            const radios = document.querySelectorAll(`input[name="q_${qId}"]`);
            radios.forEach(r => {
                if (r.value === value) {
                    r.checked = true;
                    r.parentElement.classList.add("selected");
                }
            });
        });
    }

    // =============================
    // NEXT BUTTON (validation added)
    // =============================
    document.getElementById("nextBtn").addEventListener("click", () => {
        const radios = questions[currentQuestion].querySelectorAll('input[type="radio"]');
        const answered = Array.from(radios).some(r => r.checked);

        if (!answered) {
            alert("Please select an answer before continuing.");
            return;
        }

        currentQuestion++;
        showQuestion(currentQuestion);
    });

    // =============================
    // PREVIOUS BUTTON
    // =============================
    document.getElementById("prevBtn").addEventListener("click", () => {
        currentQuestion--;
        showQuestion(currentQuestion);
    });

    // =============================
    // SUBMIT TO BACKEND
    // =============================
    document.getElementById("finishBtn").addEventListener("click", async (e) => {
        e.preventDefault();

        const answers = sessionStorage.getItem("answers") || "{}";

        const res = await fetch("@Url.Page("/Assessment/TakeAssessment", "SaveAnswers")", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]')?.value
            },
            body: answers
        });

        if (res.ok) {
            window.location.href = "@Url.Page("/Assessment/ConfirmSubmission")";
        } else {
            alert("Could not save answers. Please try again.");
        }
    });

    // =============================
    // INIT
    // =============================
    restoreAnswers();
    showQuestion(0);
</script>

<form method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>