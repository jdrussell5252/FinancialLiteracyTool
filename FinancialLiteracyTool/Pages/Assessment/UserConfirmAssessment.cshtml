@page
@model FinancialLiteracyTool.Pages.Assessment.UserConfirmAssessmentModel
@{
    ViewData["Title"] = "Start Assessment";
}

<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
    <div class="card shadow-sm p-4 text-center" style="max-width: 420px; width: 100%;">

        <h2 class="mb-3">Ready to Start?</h2>

        <p class="text-muted mb-4">
            This assessment must be completed in one sitting.
            Once started, you may not be able to go back.
        </p>

        <a asp-page="/Assessment/TakeAssessment"
           class="btn btn-primary btn-lg w-100">
            Start Assessment
        </a>

        <p class="text-muted mt-3 small">
            Please ensure you have enough time before beginning.
        </p>

    </div>
</div>
