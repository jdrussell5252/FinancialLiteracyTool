@page
@model FinancialLiteracyTool.Pages.AdminPages.AdminAssessment.BrowseAssessmentsModel
@{
}

<div class="container mt-4">

    <div class="row text-center mb-4">
        <div class="col-12">
            <h1>Browse Assessments</h1>
        </div>
    </div>

    <!-- Add Button -->
    <div class="row mb-3">
        <div class="col-12">
            <a asp-page="AddAssessment" class="btn btn-primary">
                <i class="bi bi-plus-square"></i> Add Assessment
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (Model.Assessments.Count != 0)
    {

        <div class="row">

            @foreach (var LocalAssessment in Model.Assessments)
            {
                <div class="col-md-6 col-lg-4 col-xl-3 mb-4">

                    <div class="card shadow-sm h-100">

                        <div class="card-body text-center">

                            <h5 class="card-title">
                                @LocalAssessment.AssessmentName
                            </h5>

                            @if (!string.IsNullOrWhiteSpace(LocalAssessment.AssessmentDescription))
                            {
                            <p class="card-text text-muted small">
                                @LocalAssessment.AssessmentDescription
                            </p>
                            }

                        </div>

                        <div class="card-footer d-flex justify-content-between">

                            <!-- Edit -->
                            <a asp-page="EditAssessment"
                               asp-route-id="@LocalAssessment.AssessmentID"
                               class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil-square"></i> Edit
                            </a>

                            <!-- Delete -->
                            <form method="post" asp-page-handler="Delete">
                                <input type="hidden"
                                       name="id"
                                       value="@LocalAssessment.AssessmentID" />

                                <button onclick="return confirm('Are you sure?')"
                                        class="btn btn-sm delete-btn">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </form>

                        </div>

                    </div>

                </div>
            }

        </div>

        @if (Model.TotalCount > 0)
        {
            <div class="text-center my-4">

                <div class="pagination justify-content-center">

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.PageNumber)
                        {
                            <span class="page-number active">@i</span>
                        }
                        else
                        {
                            <a class="page-number"
                               asp-page="./BrowseAssessments"
                               asp-route-pageNumber="@i"
                               asp-route-pageSize="@Model.PageSize">
                                @i
                            </a>
                        }
                    }

                </div>

            </div>
        }

    }
    else
    {
        <div class="text-center my-4">
            <h4>No Assessments yet.</h4>
        </div>
    }

</div>