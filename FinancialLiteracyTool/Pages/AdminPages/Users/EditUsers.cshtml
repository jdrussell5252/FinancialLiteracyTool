@page
@model FinancialLiteracyTool.Pages.AdminPages.Users.EditUsersModel
@{
}

<div class="container mt-4">
    <div class="row text-center">
        <div class="col-12">
            <label class="form-label fs-1" id="LabelText">Edit User</label>
        </div>
    </div>

    <form method="post" enctype="multipart/form-data">
        <div class="row my-2">
            <div class="col-12">
                <label asp-for="Profile.SystemUserFirstName" class="form-label" id="LabelText">Change First Name:</label>
            </div>
            <div class="col-12">
                <input asp-for="Profile.SystemUserFirstName" type="text" class="form-control" />
                <span asp-validation-for="Profile.SystemUserFirstName" class="text-danger"></span>
            </div>
        </div>
        <div class="row my-2">
            <div class="col-12">
                <label asp-for="Profile.SystemUserLastName" class="form-label" id="LabelText">Change Last Name:</label>
            </div>
            <div class="col-12">
                <input asp-for="Profile.SystemUserLastName" type="text" class="form-control" />
                <span asp-validation-for="Profile.SystemUserLastName" class="text-danger"></span>
            </div>
        </div>
        <div class="row my-2">
            <div class="col-12">
                <label asp-for="Profile.SystemUserName" class="form-label" id="LabelText">Change Username:</label>
            </div>
            <div class="col-12">
                <input asp-for="Profile.SystemUserName" type="text" class="form-control" />
                <span asp-validation-for="Profile.SystemUserName" class="text-danger"></span>
            </div>
        </div>
        <div class="row my-2">
            <div class="row my-2">
                <div class="col-4">
                    <label asp-for="Profile.SystemUserRole" class="form-label" id="LabelText">Role:</label>
                </div>
                <div class="col-12">
                    <select asp-for="Profile.SystemUserRole" class="form-control">
                        <option value="1">User</option>
                        <option value="2">Coach</option>
                        <option value="3">Admin</option>
                    </select>
                    <span asp-validation-for="Profile.SystemUserRole" class="text-danger"></span>
                </div>
            </div>
            <div class="row my-2" id="coachDropdownContainer" style="display:none;">
                <div class="col-4">
                    <label class="form-label" id="LabelText">Assign Coach:</label>
                </div>
                <div class="col-12">
                    <select asp-for="SelectedCoachID" asp-items="Model.Coaches" class="form-control">
                        <option value="">-- Select Coach --</option>
                    </select>
                </div>
            </div>
        <div class="row my-2">
            <div class="col-12">
                <button type="submit" class="form-control btn btn-primary">Confirm Edit</button>
            </div>
        </div>
    </form>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const roleDropdown = document.querySelector('[name="Profile.SystemUserRole"]');
        const coachContainer = document.getElementById("coachDropdownContainer");

        // You pass this from backend
        const hasCoach = @Model.HasCoach.ToString().ToLower();

        function toggleCoachDropdown() {
            if (roleDropdown.value === "1" && !hasCoach) {
                coachContainer.style.display = "block";
            } else {
                coachContainer.style.display = "none";
            }
        }

        // Initial check
        toggleCoachDropdown();

        // On change
        roleDropdown.addEventListener("change", toggleCoachDropdown);
    });
</script>